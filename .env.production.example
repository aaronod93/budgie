# Production environment — copy to `.env` on the server and fill in.
# Used by docker-compose.prod.yml (interpolation) AND the API containers.
#
# The API domain MUST be a subdomain of the app domain (api.lilbudgie.com
# under lilbudgie.com) so the Sanctum session cookie spans both.

# --- Domains (also set BUDGIE_APP_DOMAIN / BUDGIE_API_DOMAIN in StaceLib's .env) ---
APP_DOMAIN=lilbudgie.com
API_DOMAIN=api.lilbudgie.com

# --- Laravel ---
APP_NAME="Lil' Budgie"
APP_ENV=production
APP_DEBUG=false
# php artisan key:generate --show   (run locally, paste result)
APP_KEY=
APP_URL=https://${API_DOMAIN}
FRONTEND_URL=https://${APP_DOMAIN}

# Sanctum SPA cookie auth across the two subdomains.
SANCTUM_STATEFUL_DOMAINS=${APP_DOMAIN}
SESSION_DOMAIN=.${APP_DOMAIN}
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true

LOG_CHANNEL=stderr
LOG_LEVEL=warning

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=budgie
DB_USERNAME=budgie
DB_PASSWORD=change-me-to-something-long

QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_HOST=redis

# --- Websockets (Reverb) ---
# The API publishes to the reverb container directly; browsers connect via
# wss on the API domain (Caddy proxies /app/* to reverb).
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=budgie
REVERB_APP_KEY=change-me-random-key
REVERB_APP_SECRET=change-me-random-secret
REVERB_HOST=budgie-reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# --- Outgoing email (invitations, password resets) ---
# Any SMTP provider works (SES, Postmark, Resend, Mailgun...).
MAIL_MAILER=smtp
MAIL_HOST=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="no-reply@${APP_DOMAIN}"
MAIL_FROM_NAME="${APP_NAME}"

# --- Google sign-on (optional; leave empty to disable) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
